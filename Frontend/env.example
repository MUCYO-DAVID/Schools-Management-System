# Copy to .env.local for local dev
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# ─── Vercel (frontend + backend on same project) ───
# 1. Vercel → Project Settings → General → Root Directory = . (repo root, NOT Frontend)
# 2. Enable "Include source files outside of the Root Directory" if prompted
# 3. Do NOT set NEXT_PUBLIC_BACKEND_URL — the app uses same-origin /api on Vercel
# 4. Add ALL backend env vars in Vercel → Settings → Environment Variables:
#    DATABASE_URL, JWT_SECRET, GROQ_API_KEY, EMAIL_SERVICE, EMAIL_USER, EMAIL_PASSWORD, EMAIL_FROM
# 5. You can shut down the Render backend after Vercel deploy works

# ─── Legacy split deploy (Render backend + Vercel frontend only) ───
# NEXT_PUBLIC_BACKEND_URL=https://rwandaschoolsbridgesystem.onrender.com
