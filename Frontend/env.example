# Copy to .env.local for local dev
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# Vercel production — set in Project → Settings → Environment Variables:
# NEXT_PUBLIC_BACKEND_URL=https://rwandaschoolsbridgesystem.onrender.com

# Render production — set in Backend service → Environment (see Backend/env.example):
# DATABASE_URL, JWT_SECRET, FRONTEND_URL, GROQ_API_KEY,
# EMAIL_SERVICE + EMAIL_USER + EMAIL_PASSWORD (EMAIL_FROM must match EMAIL_USER for Gmail)
