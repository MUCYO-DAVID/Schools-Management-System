# Core
PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/rsbs
JWT_SECRET=your-secret-key-here
FRONTEND_URL=http://localhost:3000

# Email — required in production for OTP login
# Option 1: Gmail (use an App Password, not your regular password)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM=Rwanda School Bridge System <your-email@gmail.com>

# Option 2: Custom SMTP
# EMAIL_SERVICE=smtp
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password

# Option 3: Resend (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Rwanda School Bridge System <onboarding@resend.dev>

# Optional
STRIPE_SECRET_KEY=
GROQ_API_KEY=
