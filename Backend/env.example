# Copy to Backend/.env for local dev — mirror these EXACT keys on Render → Environment
#
# Render service settings (Dashboard → Settings → Build & Deploy):
#   Root Directory: Backend
#   Build Command:  npm install   (or leave default — package.json includes a build script)
#   Start Command:  node server.js

PORT=5000
DATABASE_URL=your-supabase-or-postgres-url
JWT_SECRET=your-long-random-secret
FRONTEND_URL=https://rwandaschoolbridgesystem.vercel.app

GROQ_API_KEY=gsk_your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL — HYBRID SETUP (auto-detected, no code changes between environments)
#   • Local dev  -> Gmail SMTP   (works on your PC; ports 587/465 are open)
#   • Production -> Brevo HTTP API (Render blocks SMTP ports; Brevo uses HTTPS/443)
# The provider is chosen by which keys are present:
#   BREVO_API_KEY set  -> Brevo   |   otherwise SMTP_USER/SMTP_PASSWORD -> Gmail SMTP
# ─────────────────────────────────────────────────────────────────────────────

EMAIL_FROM=Rwanda School Bridge System <your-email@gmail.com>

# --- LOCAL DEV (Backend/.env) — Gmail SMTP. Do NOT set BREVO_API_KEY locally. ---
EMAIL_SERVICE=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-gmail-app-password

# --- PRODUCTION (Render → Environment) — add this ONE extra key to switch to Brevo:
#   BREVO_API_KEY=xkeysib-...   (Brevo → Settings → SMTP & API → API Keys; must start with xkeysib-)
# Keep EMAIL_FROM the same. The sender email in EMAIL_FROM must be a VERIFIED sender in Brevo.
# In Brevo → Security → Authorized IPs: turn OFF IP restriction (Render IPs change).
# SMTP_* vars can stay on Render — they are ignored once BREVO_API_KEY is present.

# After deploy, verify: https://rwandaschoolbridgesystem.onrender.com/api/health/email
#   -> emailReady:true, service:"brevo", transport:"https-api"
# If service shows "smtp" with a timeout, BREVO_API_KEY is missing/invalid on Render.

# Do NOT put NEXT_PUBLIC_BACKEND_URL on Render — that belongs on Vercel only.
