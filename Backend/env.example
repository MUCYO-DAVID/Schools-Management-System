# Core
PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/rsbs
JWT_SECRET=your-secret-key-here
FRONTEND_URL=http://localhost:3000
# Comma-separated extra frontend URLs (Vercel preview + production)
# FRONTEND_URLS=https://your-app.vercel.app,https://www.your-domain.com

# Groq AI — required on Render for the chatbot (same key as localhost)
GROQ_API_KEY=gsk_your_groq_api_key
# GROQ_MODEL=llama-3.3-70b-versatile

# Email — required in production for OTP login
# IMPORTANT: EMAIL_FROM must match EMAIL_USER for Gmail or emails may not arrive.
# Option 1: Gmail (use an App Password, not your regular password)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM=Rwanda School Bridge System <your-email@gmail.com>

# Option 2: Custom SMTP (Brevo, SendGrid, etc.)
# EMAIL_SERVICE=smtp
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password
# EMAIL_FROM=Rwanda School Bridge System <noreply@yourdomain.com>

# Option 3: Resend (https://resend.com) — verify your domain for best delivery
# EMAIL_SERVICE=resend
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=Rwanda School Bridge System <noreply@yourdomain.com>

# Optional
STRIPE_SECRET_KEY=
