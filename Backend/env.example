# Copy to Backend/.env for local dev — mirror production keys on Render → Environment
#
# Render: Root Directory = Backend, Start = node server.js
# Verify: https://rwandaschoolbridgesystem.onrender.com/api/health/email
#   emailReady MUST be true

PORT=5000
DATABASE_URL=your-supabase-or-postgres-url
JWT_SECRET=your-long-random-secret
FRONTEND_URL=https://rwandaschoolbridgesystem.vercel.app

GROQ_API_KEY=gsk_your_groq_key
GROQ_MODEL=llama-3.3-70b-versatile

# ─── PRODUCTION ON RENDER (required) — Brevo HTTP API ───
# SMTP (ports 587/465) is BLOCKED on Render. Use Brevo API over HTTPS instead.
#
# 1. https://www.brevo.com → sign up
# 2. Senders → verify mucyobecks@gmail.com
# 3. Settings → SMTP & API → API Keys → Create (starts with xkeysib-)
#    ⚠️ NOT the SMTP key (xsmtpsib-) — you need the API key (xkeysib-)
# 4. On Render Environment:
EMAIL_SERVICE=brevo
BREVO_API_KEY=xkeysib-your-brevo-api-key
EMAIL_FROM=Rwanda School Bridge System <mucyobecks@gmail.com>

# ─── LOCAL DEV ONLY — Gmail SMTP works on your PC ───
# EMAIL_SERVICE=smtp
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-gmail-app-password

# Do NOT put NEXT_PUBLIC_BACKEND_URL on Render — Vercel only.
