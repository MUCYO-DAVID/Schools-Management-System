# Local dev — copy to Backend/.env
PORT=5000
NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/rsbs
JWT_SECRET=your-secret-key-here
FRONTEND_URL=http://localhost:3000

# Groq AI
GROQ_API_KEY=gsk_your_groq_api_key

# Email (OTP) — EMAIL_FROM must match EMAIL_USER for Gmail
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_FROM=Rwanda School Bridge System <your-email@gmail.com>

# ─── Vercel: add the same variables in Project → Environment Variables ───
# No FRONTEND_URL needed when frontend and API share one Vercel domain.
